# ============================================================
# Frame-sim — Frontend (Vite) — copie para .env e preencha
# As chaves serao rotacionadas periodicamente; nunca commitar .env
# ============================================================

# Gemini (obrigatoria — sem ela o modo standard cai em resultado mock)
VITE_API_KEY=

# Chaves Gemini extras (opcionais) — rotacao round-robin anti rate-limit
VITE_API_KEY_2=
VITE_API_KEY_3=
VITE_API_KEY_4=
VITE_API_KEY_5=
VITE_API_KEY_6=
VITE_API_KEY_7=

# Fallbacks (opcionais) — usados se todas as chaves Gemini falharem
VITE_OPENAI_API_KEY=
VITE_DEEPSEEK_API_KEY=
