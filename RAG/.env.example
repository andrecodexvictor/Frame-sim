# ============================================================
# Frame-sim — Backend agentico (RAG/) — copie para RAG/.env
# As chaves serao rotacionadas periodicamente; nunca commitar .env
# ============================================================

# Gemini (obrigatoria — LLM principal e embeddings text-embedding-004)
GOOGLE_API_KEY=

# Chaves Gemini extras (opcionais) — round-robin no GeminiProvider
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=

# Modelo Gemini padrao (opcional; default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Fallbacks multi-LLM (opcionais) — SmartRouter/LLMFactory
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Ollama local (opcional) — roteador de intencao do SmartRouter
# OLLAMA_BASE_URL=http://localhost:11434

# ChromaDB (opcional — sem ele o RAG e desativado em fail-open)
# CHROMA_URL=http://localhost:8000
# CHROMA_DB_PATH=./chroma_db
